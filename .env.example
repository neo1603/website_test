# Copy this file to .env and fill in your real Firebase project values.
# .env is already gitignored — never commit real credentials.
#
# Get these from: Firebase Console → Project Settings → General → Your apps → SDK setup and configuration

REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=
REACT_APP_FIREBASE_MEASUREMENT_ID=

# Image hosting for admin project photo uploads (Cloudinary free tier — no
# billing card required, unlike Firebase Storage which now needs Blaze).
# 1. Sign up free at cloudinary.com, no card needed.
# 2. Your cloud name is shown on the Cloudinary dashboard homepage.
# 3. Settings → Upload → Upload presets → Add upload preset → set
#    "Signing Mode" to "Unsigned" → save, then paste its name below.
REACT_APP_CLOUDINARY_CLOUD_NAME=
REACT_APP_CLOUDINARY_UPLOAD_PRESET=
